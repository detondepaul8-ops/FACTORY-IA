generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  password          String
  role              String             @default("user")
  credits           Int                @default(50)
  plan              String             @default("free")
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  apiKeys            ApiKey[]
  creditTransactions CreditTransaction[]
  queryLogs          QueryLog[]
  subscriptions      Subscription[]
  momoTransactions   MomoTransaction[]
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  queryLogs QueryLog[]
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String
  referenceId String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QueryLog {
  id            String   @id @default(cuid())
  userId        String?
  apiKeyId      String?
  message       String
  response      String
  strategy      String
  aiModelsUsed  String
  webSources    String?
  creditsCost   Int      @default(1)
  responseTime  Int
  createdAt     DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  plan            String
  creditsPerMonth Int      @default(100)
  price           Int
  status          String   @default("active")
  startDate       DateTime @default(now())
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MomoTransaction {
  id             String   @id @default(cuid())
  userId         String
  phoneNumber    String
  amount         Int
  creditsGranted Int
  status         String
  provider       String
  externalRef    String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Système de gestion des fournisseurs IA ───────────────────────────────────

model AIProvider {
  id               String   @id @default(cuid())
  slug             String   @unique // "gemini", "claude", "openrouter", etc.
  name             String   // "Google Gemini"
  description      String   // "Général + Raisonnement"
  baseUrl          String   // URL de l'API
  defaultModel     String   // "gemini-2.5-flash"
  apiType          String   @default("openai") // openai, gemini, custom
  authHeader       String   @default("Bearer") // "Bearer", "x-goog-api-key"
  authPrefix       String   // "" pour Gemini (key dans query), "Bearer " pour OpenAI
  isActive         Boolean  @default(true)
  priority         Int      @default(0) // plus élevé = priorisé
  strengths        String   // JSON: ["general","analysis","code"]
  languages        String   // JSON: ["fr","en"]
  speed            Int      @default(3) // 1-5
  apiKeyEncrypted  String   // clé API chiffrée (base64 encodé, en production utiliser crypto)
  lastHealthCheck  DateTime?
  healthStatus     String   @default("unknown") // healthy, unhealthy, unknown
  healthMessage    String?
  lastError        String?
  lastErrorAt      DateTime?
  totalCalls       Int      @default(0)
  successCalls     Int      @default(0)
  failedCalls      Int      @default(0)
  avgLatencyMs     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  errorLogs ProviderErrorLog[]
}

model ProviderErrorLog {
  id          String    @id @default(cuid())
  providerId  String
  provider    AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  errorCode   String?   // "401", "429", "500"
  errorMessage String
  requestInfo  String?  // JSON résumé de la requête
  createdAt   DateTime  @default(now())
}